{
  "manifest_version": 3,
  "name": "Meet Captions Collector",
  "version": "0.1.0",
  "description": "Collects Google Meet closed captions locally and hands the transcript off to an LLM (Claude / ChatGPT) for summary, action items and follow-ups.",
  "permissions": ["sidePanel", "clipboardWrite"],
  "host_permissions": ["https://meet.google.com/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "action": {
    "default_title": "Meet Captions Collector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
